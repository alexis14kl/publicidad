{
  "name": "bot-publicitario-gui",
  "version": "1.0.0",
  "description": "GUI para Bot Publicitario NoyeCode",
  "main": "electron/bootstrap.js",
  "scripts": {
    "dev": "concurrently \"node ./node_modules/vite/dist/node/cli.js --strictPort --port 5173\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:frontend": "node ./node_modules/vite/dist/node/cli.js build",
    "build": "node ./node_modules/vite/dist/node/cli.js build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.noyecode.bot-publicitario",
    "productName": "Bot Publicitario NoyeCode",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
