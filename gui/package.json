{
  "name": "bot-publicitario-gui",
  "version": "1.0.0",
  "description": "GUI para Bot Publicitario NoyeCode",
  "main": "electron/bootstrap.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:frontend": "vite build",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.noyecode.bot-publicitario",
    "productName": "Bot Publicitario NoyeCode",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "extraResources": [
        {
          "from": "../server",
          "to": "backend/server"
        },
        {
          "from": "../utils",
          "to": "backend/utils"
        },
        {
          "from": "../run_mac",
          "to": "backend/run_mac"
        },
        {
          "from": "../cfg",
          "to": "backend/cfg"
        },
        {
          "from": "../cdp",
          "to": "backend/cdp"
        },
        {
          "from": "../inicio",
          "to": "backend/inicio"
        },
        {
          "from": "../perfil",
          "to": "backend/perfil"
        },
        {
          "from": "../prompt",
          "to": "backend/prompt"
        },
        {
          "from": "../n8n",
          "to": "backend/n8n"
        },
        {
          "from": "../memory",
          "to": "backend/memory"
        },
        {
          "from": "../logs",
          "to": "backend/logs"
        },
        {
          "from": "../.job_poller_state.json",
          "to": "backend/.job_poller_state.json"
        },
        {
          "from": "../.prompt_last_send.json",
          "to": "backend/.prompt_last_send.json"
        },
        {
          "from": "../.service_rotation_state.json",
          "to": "backend/.service_rotation_state.json"
        }
      ]
    }
  }
}
