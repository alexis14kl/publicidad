=
# ============================================================
# Meta Ads — Marketing API (requerido para campañas)
# ============================================================
# App ID y App Secret: developers.facebook.com > Tu App > Configuracion > Basica
#   Requeridos para: obtener tokens, OAuth login, extender tokens
FB_APP_ID=
FB_APP_SECRET=
FB_OAUTH_REDIRECT_URI=https://localhost:3000/auth/facebook/callback
=
# Access Token: genera un System User token en Meta Business Suite
#   business.facebook.com > Configuracion > Usuarios del sistema > Generar token
#   Permisos: ads_management, ads_read, leads_retrieval, pages_manage_ads, pages_read_engagement, pages_show_list
FB_ACCESS_TOKEN=
#
# Page Access Token (se obtiene via /me/accounts o se auto-genera si tiene el User Token)
FB_PAGE_ACCESS_TOKEN=
#
# Page ID: ID numerico de la pagina de Facebook
FB_PAGE_ID=115406607722279

=
# Ad Account ID: cuenta publicitaria (con prefijo act_)
#   business.facebook.com > Configuracion > Cuentas > Cuentas publicitarias
FB_AD_ACCOUNT_ID=act_438871067037500

=
